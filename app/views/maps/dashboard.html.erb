  <!-- ヘッダー -->
  <header class="header">
    <%= link_to 'HoCarDoPlan', authenticated_root_path, class: 'header-logo' %>
    <div class="welcome">ようこそ <%= current_user.nickname %> さん</div>
    <button type="button" id="hamburger-btn" class="hamburger-btn">☰</button>
  </header>


<div class="main-contents">
  <!-- インストラクション -->
  <div class="instructions">
    ピンを押して詳細を確認しましょう。<br>
    スタンプ押印済みを登録しましょう。
  </div>

  <!-- 地図の表示領域 -->
    <div id="map1"></div>
    
    <!-- 道の駅詳細モーダル -->
    <div id="station-modal" class="custom-modal">
      <div class="custom-modal-content">
        <span id="close-modal" class="close-button">&times;</span>
        <h2>道の駅: <span id="stationName">○○</span></h2>
        <p><strong>休館日:</strong> <span id="closedDays"></span></p>
        <p><strong>開館時間:</strong></p>
        <ul id="businessHours"></ul>
        <p><strong>スタンプ押印時間:</strong></p>
        <p id="stampHours">開館時間に同じ ※休館日は押せません</p>
        <div id="stamp-date-section" style="margin: 10px 0;">
          <label for="stamp-visited-at" style="font-size:14px; font-weight:bold;">押印日:</label>
          <input type="date" id="stamp-visited-at" style="margin-left:8px; font-size:14px; padding:4px 8px; border:1px solid #ccc; border-radius:4px;">
        </div>
        <button id="stampButton" class="stamp-btn">スタンプを押す</button>
      </div>
    </div>


    <!--　日程を作成するモーダル　---->
    <div id="itinerary-modal" class="custom-modal">
      <div class="custom-modal-content">
        <span id="close-itinerary-modal" class="close-button">&times;</span>
        <h2>日程を作成</h2>
        <%= render partial: "itineraries/new", locals: { itinerary: @itinerary } %>
      </div>
    </div>
  </div>


  <!-- フッター -->
  <footer class="footer">
  <div class="footer-container">
    <!-- モーダルを開くボタン -->
    <a id="open-itinerary-modal" href="#" class="footer-link">日程を<br>作成する</a>
  </div>
  </footer>