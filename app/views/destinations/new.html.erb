<!-- ヘッダー -->
  <header class="header">
    <div class="welcome">
      <%= @itinerary.title %> <br> <%= @display_date %>（<%= @day_label %>)
    </div>
    <%= link_to 'ログアウト', destroy_user_session_path, data: { turbo_method: :delete }, class: 'logout-button' %>
  </header>

<main>
<div class="main-contents">
  <!-- インストラクション -->
  <div class="instructions">
    出発地を登録したら<br>
    経路を登録してしおりを作成しましょう
  </div>
 

  <div class="map-container">
    <!-- 地図の表示領域 -->
    <div class="map-container">
      <div id="itinerary-data" data-itinerary-id="<%= @itinerary.id %>" data-start-date="<%= @start_date %>" data-current-day="<%= @current_day %>"
        <% if @previous_last_destination %>
          data-prev-destination-name="<%= @previous_last_destination.destination %>"
          data-prev-destination-lat="<%= @previous_last_destination.destination_latitude %>"
          data-prev-destination-lng="<%= @previous_last_destination.destination_longitude %>"
        <% end %>
        <% if @previous_destinations.present? %>
          data-prev-destinations="<%= @previous_destinations.to_json %>"
        <% end %>
        <% if @existing_starting_point %>
          data-existing-sp-name="<%= @existing_starting_point.starting_point %>"
          data-existing-sp-lat="<%= @existing_starting_point.starting_point_latitude %>"
          data-existing-sp-lng="<%= @existing_starting_point.starting_point_longitude %>"
        <% end %>
        <% if @existing_destinations.present? %>
          data-existing-destinations="<%= @existing_destinations.map { |d| { name: d.destination } }.to_json %>"
        <% end %>
      ></div>
      <div id="stations-data" data-stations="<%= @stations.select(:name, :kana, :latitude, :longitude).to_json %>"></div>
      <div id="map2"></div>
    </div>

    <!-- 出発地登録領域 -->
    <div class="starting-point-form"
      <% if @home_address.present? %>
        data-home-address="<%= @home_address %>"
        data-home-lat="<%= @home_latitude %>"
        data-home-lng="<%= @home_longitude %>"
      <% end %>
    >
      <% route_mode = @existing_starting_point.present? || @previous_last_destination.present? %>
      <label for="starting-point" class="starting-point-heading"><%= route_mode ? '経路を選択する:' : '出発地点を選ぶ:' %></label>
      <button type="button" id="search-location"<%= ' style="display:none"'.html_safe if route_mode %>>現在地を選ぶ</button>
      <% if @home_address.present? %>
        <button type="button" id="select-home"<%= ' style="display:none"'.html_safe if route_mode %>>🏠 自宅</button>
      <% end %>
      <div class="place-search-container">
        <input type="text" id="place-search-input" placeholder="住所・施設名で検索">
      </div>
      <button type="button" id="register-starting-point"<%= ' style="display:none"'.html_safe if route_mode %>>出発地を登録する</button>
      <div id="route-list"></div>
    </div>
  </div>
</div>
</main>

<!-- フッター -->
<footer class="footer">
  <div class="footer-container">
    <a id="save-route-btn" href="#" class="footer-link">しおり<br>作成</a>
  </div>
</footer>