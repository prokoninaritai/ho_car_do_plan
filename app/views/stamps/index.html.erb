<!-- ヘッダー -->
<header class="header">
  <%= link_to 'HoCarDoPlan', authenticated_root_path, class: 'header-logo' %>
  <div class="welcome">マイページ</div>
  <button type="button" id="hamburger-btn" class="hamburger-btn">☰</button>
</header>

<main>
<div class="main-contents" style="overflow-y:auto; height:auto; padding-bottom:80px;">

  <!-- 進捗 -->
  <div class="stamp-progress">
    <div class="stamp-progress-text">
      <span class="stamp-count"><%= @stamp_count %></span>
      <span class="stamp-total"> / <%= @total_count %> 枚</span>
    </div>
    <div class="stamp-progress-bar-wrap">
      <div class="stamp-progress-bar" style="width:<%= (@total_count > 0 ? (@stamp_count.to_f / @total_count * 100).round : 0) %>%;"></div>
    </div>
    <div class="stamp-progress-pct">
      <%= (@total_count > 0 ? (@stamp_count.to_f / @total_count * 100).round : 0) %>%
    </div>
  </div>

  <!-- タブ -->
  <div class="stamp-tabs">
    <button class="stamp-tab active" data-target="stamped-section">押印済み（<%= @stamp_count %>）</button>
    <button class="stamp-tab" data-target="unstamped-section">未押印（<%= @total_count - @stamp_count %>）</button>
  </div>

  <!-- 押印済み一覧 -->
  <div id="stamped-section" class="stamp-section active">
    <% if @stamp_count == 0 %>
      <p class="stamp-empty">まだスタンプが登録されていません。</p>
    <% else %>
      <% @regions.each do |region, entries| %>
        <% stamped_entries = entries.select { |e| e[:stamped] } %>
        <% next if stamped_entries.empty? %>
        <div class="stamp-region-group">
          <div class="stamp-region-header"><%= region %></div>
          <% stamped_entries.each do |entry| %>
            <div class="stamp-item stamped">
              <span class="stamp-icon">🟢</span>
              <span class="stamp-name"><%= entry[:station].name %></span>
              <span class="stamp-date"><%= entry[:visited_at]&.strftime('%Y/%m/%d') %></span>
            </div>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </div>

  <!-- 未押印一覧 -->
  <div id="unstamped-section" class="stamp-section">
    <% @regions.each do |region, entries| %>
      <% unstamped_entries = entries.reject { |e| e[:stamped] } %>
      <% next if unstamped_entries.empty? %>
      <div class="stamp-region-group">
        <div class="stamp-region-header"><%= region %></div>
        <% unstamped_entries.each do |entry| %>
          <div class="stamp-item">
            <span class="stamp-icon">⚪</span>
            <span class="stamp-name"><%= entry[:station].name %></span>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

</div>
</main>

<!-- フッター -->
<footer class="footer">
  <div class="footer-container">
    <%= link_to 'アカウント<br>設定'.html_safe, edit_user_registration_path, class: 'footer-link' %>
    <%= link_to 'しおり<br>一覧'.html_safe, itineraries_path, class: 'footer-link' %>
    <%= link_to 'トップに<br>戻る'.html_safe, authenticated_root_path, class: 'footer-link' %>
  </div>
</footer>

<style>
  body.stamps-page { overflow: auto !important; }
  body.stamps-page .main-contents {
    overflow: auto !important;
    height: auto !important;
  }

  /* 進捗 */
  .stamp-progress {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 16px;
    background: #fff;
    border-bottom: 1px solid #eee;
  }
  .stamp-progress-text {
    flex-shrink: 0;
    font-size: 15px;
  }
  .stamp-count {
    font-size: 22px;
    font-weight: bold;
    color: #4CAF50;
  }
  .stamp-total {
    color: #888;
  }
  .stamp-progress-bar-wrap {
    flex: 1;
    height: 10px;
    background: #e8e8e8;
    border-radius: 5px;
    overflow: hidden;
  }
  .stamp-progress-bar {
    height: 100%;
    background: #4CAF50;
    border-radius: 5px;
    transition: width 0.4s;
  }
  .stamp-progress-pct {
    flex-shrink: 0;
    font-size: 13px;
    color: #555;
    min-width: 36px;
    text-align: right;
  }

  /* タブ */
  .stamp-tabs {
    display: flex;
    border-bottom: 2px solid #4CAF50;
    background: #fff;
  }
  .stamp-tab {
    flex: 1;
    padding: 10px 0;
    border: none;
    background: #e8e8e8;
    font-size: 14px;
    font-weight: bold;
    color: #666;
    cursor: pointer;
    border-right: 1px solid #ddd;
  }
  .stamp-tab:last-child { border-right: none; }
  .stamp-tab.active {
    background: #4CAF50;
    color: #fff;
  }

  /* セクション */
  .stamp-section { display: none; }
  .stamp-section.active { display: block; }

  /* 地域グループ */
  .stamp-region-group {
    margin: 0;
  }
  .stamp-region-header {
    padding: 8px 16px;
    background: #f5f5f5;
    font-size: 13px;
    font-weight: bold;
    color: #555;
    border-bottom: 1px solid #ddd;
    border-top: 1px solid #ddd;
  }

  /* 各駅アイテム */
  .stamp-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 16px;
    border-bottom: 1px solid #f0f0f0;
    background: #fff;
  }
  .stamp-icon { font-size: 16px; flex-shrink: 0; }
  .stamp-name { flex: 1; font-size: 14px; color: #333; }
  .stamp-date { font-size: 12px; color: #888; flex-shrink: 0; }

  .stamp-empty {
    text-align: center;
    color: #999;
    padding: 32px 0;
    font-size: 14px;
  }
</style>

<script>
document.addEventListener("turbo:load", function() {
  if (document.getElementById('stamped-section')) {
    document.body.classList.add('stamps-page');
  } else {
    document.body.classList.remove('stamps-page');
  }

  document.querySelectorAll('.stamp-tab').forEach(function(tab) {
    tab.addEventListener('click', function() {
      document.querySelectorAll('.stamp-tab').forEach(function(t) { t.classList.remove('active'); });
      document.querySelectorAll('.stamp-section').forEach(function(s) { s.classList.remove('active'); });
      this.classList.add('active');
      document.getElementById(this.dataset.target).classList.add('active');
    });
  });
});
</script>
