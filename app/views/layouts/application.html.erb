<!DOCTYPE html>
<html>

<head>
  <title>HoCarDoPlan</title>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
  <!-- Google Maps API -->
  <script>window.initMap = function() {};</script>
  <script
    src="https://maps.googleapis.com/maps/api/js?key=<%= ENV['GOOGLE_MAPS_API_KEY'] %>&libraries=places&callback=initMap"
    async
    defer>
  </script>
</head>

<body>
  <!-- ハンバーガーメニュー オーバーレイ -->
  <div id="drawer-overlay" class="drawer-overlay"></div>

  <!-- ドロワー -->
  <nav id="drawer" class="drawer">
    <button id="drawer-close" class="drawer-close">✕</button>
    <ul class="drawer-menu">
      <li><%= link_to '🏠 トップ', authenticated_root_path, class: 'drawer-link' %></li>
      <li><%= link_to '📋 しおり一覧', itineraries_path, class: 'drawer-link' %></li>
      <li><%= link_to '👤 アカウント', users_home_path, class: 'drawer-link' %></li>
      <li><%= link_to '🏷️ スタンプ一覧', stamps_path, class: 'drawer-link' %></li>
      <li class="drawer-divider"></li>
      <li><%= link_to 'ログアウト', destroy_user_session_path, data: { turbo_method: :delete }, class: 'drawer-link drawer-logout' %></li>
    </ul>
  </nav>

  <%= yield %>

  <script>
    document.addEventListener('turbo:load', function() {
      var overlay = document.getElementById('drawer-overlay');
      var drawer  = document.getElementById('drawer');
      var closeBtn = document.getElementById('drawer-close');

      function openDrawer() {
        drawer.classList.add('open');
        overlay.classList.add('open');
      }
      function closeDrawer() {
        drawer.classList.remove('open');
        overlay.classList.remove('open');
      }

      // 各ページのハンバーガーボタンに紐付け
      var hamburgerBtn = document.getElementById('hamburger-btn');
      if (hamburgerBtn) {
        hamburgerBtn.addEventListener('click', openDrawer);
      }
      if (closeBtn)  closeBtn.addEventListener('click', closeDrawer);
      if (overlay)   overlay.addEventListener('click', closeDrawer);
    });
  </script>
</body>

</html>