<!-- ヘッダー -->
  <div id="day-schedule-data"
       data-itinerary-id="<%= @itinerary.id %>"
       data-current-day="<%= @current_day %>"
       data-total-days="<%= @total_days %>"
       data-visit-date="<%= @visit_date.strftime('%m-%d') %>"
       data-visit-wday="<%= @visit_date.wday %>"
       data-visit-mday="<%= @visit_date.day %>"></div>
  <header class="header">
    <div class="welcome">
      <%= @itinerary.title %> <br>
      <%= @visit_date.strftime('%Y年%m月%d日') %>（<%= @current_day %>日目）
    </div>
    </div>
      <%= link_to 'ログアウト', destroy_user_session_path, data: { turbo_method: :delete }, class: 'logout-button' %>
    </div>
  </header>

<main>
<div class="itinerary-contents">
  <%# 出発時間を計算: 1番目の到着時間 - 移動時間 %>
  <% first_tm = @destinations.first&.time_management %>
  <% saved_departure = nil %>
  <% if first_tm && first_tm.arrival_time.present? && first_tm.custom_travel_time.present? %>
    <% arr = first_tm.arrival_time.split(':').map(&:to_i) %>
    <% trv = first_tm.custom_travel_time.split(':').map(&:to_i) %>
    <% total_min = (arr[0] * 60 + arr[1]) - (trv[0] * 60 + trv[1]) %>
    <% total_min += 24 * 60 if total_min < 0 %>
    <% saved_departure = format('%02d:%02d', total_min / 60, total_min % 60) %>
  <% end %>

  <!-- 出発地ブロック -->
  <div class="destination-block time-block departure-block">
    <div class="left-section">
      <label>出発時間:</label>
      <div class="time-select-group departure-time">
        <%= time_select_fields('departure-time', saved_departure) %>
      </div>
    </div>
    <div class="right-section">
      <h3>出発地:<%= @departure_name %></h3>
      <% if @departure_station %>
        <p><strong>休館日:</strong></p>
        <ul class="no-bullet">
          <% @departure_station.closed_days.each do |day| %>
            <li class="closed-day-item"
                data-closed-info="<%= day.closed_info %>"
                data-start-date="<%= day.start_date %>"
                data-end-date="<%= day.end_date %>">
              <%= day.closed_info %>
              <% if day.start_date.present? || day.end_date.present? %>
                (<%= format_date_display(day.start_date) %> 〜 <%= format_date_display(day.end_date) %>)
              <% end %>
              <% if day.remarks.present? %>
                <br><small>備考: <%= day.remarks %></small>
              <% end %>
            </li>
          <% end %>
        </ul>
        <p><strong>営業時間:</strong></p>
        <ul class="no-bullet">
          <% @departure_station.business_hours.each do |hour| %>
            <li class="business-hour-item"
                data-opening="<%= hour.opening_time.strftime('%H:%M') %>"
                data-closing="<%= hour.closing_time.strftime('%H:%M') %>"
                data-bh-start-date="<%= hour.start_date %>"
                data-bh-end-date="<%= hour.end_date %>"
                data-start-day="<%= hour.start_day %>"
                data-end-day="<%= hour.end_day %>">
              <%= "#{hour.opening_time.strftime('%H:%M')} 〜 #{hour.closing_time.strftime('%H:%M')}" %>
              (<%= format_date_display(hour.start_date) %> 〜 <%= format_date_display(hour.end_date) %>)
              <% if hour.remarks.present? %>
                <br><small><%= hour.remarks %></small>
              <% end %>
            </li>
          <% end %>
        </ul>
        <p><strong>スタンプ押印時間:</strong></p>
        <ul class="no-bullet">
          <% @departure_station.stamp_available_hours.each do |stamp| %>
            <li class="stamp-hour-item"
                data-available-hour="<%= stamp.available_hour %>"
                data-stamp-remarks="<%= stamp.remarks %>">
              <%= stamp.available_hour %>
              <% if stamp.remarks.present? %>
                <br><small><%= stamp.remarks %></small>
              <% end %>
            </li>
          <% end %>
        </ul>
      <% end %>
    </div>
  </div>

  <!-- 移動時間ブロック -->
  <div class="destination-block time-block travel-time-block">
    <div class="left-container">
      <div class="left-section">
        <label>移動時間:</label>
        <% first_travel = first_tm&.custom_travel_time&.rjust(5, '0') || @destinations.first&.api_travel_time&.rjust(5, '0') %>
        <div class="time-select-group travel-time">
          <%= time_select_fields('travel-time', first_travel) %>
        </div>
      </div>
    </div>
  </div>


  <!-- 目的地ブロック -->
  <% @destinations.each_with_index do |destination, index| %>
  <% station = @station_data.find { |s| s.name == destination.destination } %>
  <div class="destination-block destination-details-block <%= 'goal-destination' if index == @destinations.size - 1 %>"
       data-destination-id="<%= destination.id %>">
    <div class="left-container time-block">
      <div class="left-section">
        <label>到着予定時間:</label>
        <span class="arrival-time time-display">--:--</span>
      </div>
      <% unless index == @destinations.size - 1 %>
        <div class="left-section">
          <label>滞在予定時間:</label>
          <div class="time-select-group stay-time">
            <%= time_select_fields('stay-time', '00:20') %>
          </div>
        </div>
        <div class="left-section">   
          <label>出発予定時間:</label>
          <span class="next-departure-time time-display">--:--</span>
        </div>
      <% end %>
    </div>

    <div class="right-section">
      <h3>目的地:<%= destination.destination %></h3>
      <% if station %>
        <p><strong>休館日:</strong></p>
        <ul class="no-bullet">
          <% station.closed_days.each do |day| %>
            <li class="closed-day-item"
                data-closed-info="<%= day.closed_info %>"
                data-start-date="<%= day.start_date %>"
                data-end-date="<%= day.end_date %>">
              <%= day.closed_info %>
              <% if day.start_date.present? || day.end_date.present? %>
                (<%= format_date_display(day.start_date) %> 〜 <%= format_date_display(day.end_date) %>)
              <% end %>
              <% if day.remarks.present? %>
                <br><small>備考: <%= day.remarks %></small>
              <% end %>
            </li>
          <% end %>
        </ul>
        <p><strong>営業時間:</strong></p>
        <ul class="no-bullet">
          <% station.business_hours.each do |hour| %>
            <li class="business-hour-item"
                data-opening="<%= hour.opening_time.strftime('%H:%M') %>"
                data-closing="<%= hour.closing_time.strftime('%H:%M') %>"
                data-bh-start-date="<%= hour.start_date %>"
                data-bh-end-date="<%= hour.end_date %>"
                data-start-day="<%= hour.start_day %>"
                data-end-day="<%= hour.end_day %>">
              <%= "#{hour.opening_time.strftime('%H:%M')} 〜 #{hour.closing_time.strftime('%H:%M')}" %>
              (<%= format_date_display(hour.start_date) %> 〜 <%= format_date_display(hour.end_date) %>)
              <% if hour.remarks.present? %>
                <br><small><%= hour.remarks %></small>
              <% end %>
            </li>
          <% end %>
        </ul>
        <p><strong>スタンプ押印時間:</strong></p>
        <ul class="no-bullet">
          <% station.stamp_available_hours.each do |stamp| %>
            <li class="stamp-hour-item"
                data-available-hour="<%= stamp.available_hour %>"
                data-stamp-remarks="<%= stamp.remarks %>">
              <%= stamp.available_hour %>
              <% if stamp.remarks.present? %>
                <br><small><%= stamp.remarks %></small>
              <% end %>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="non-station-note">※ 道の駅以外の目的地です</p>
      <% end %>
    </div>
  </div>

  <!-- 中間の移動時間ブロック -->
  <% unless index == @destinations.size - 1 %> <!-- 最後の目的地では移動時間を表示しない -->
    <div class="destination-block time-block travel-time-block">
      <div class="left-container">
        <div class="left-section">
          <label>移動時間:</label>
          <div class="time-select-group travel-time">
            <%= time_select_fields('travel-time', @destinations[index + 1].api_travel_time.rjust(5, '0')) %>
          </div>
        </div>
      </div>
    </div>
  <% end %>
<% end %>


<!-- フッター -->
 <footer class="footer-container">
   <%= link_to '経路選択に<br>戻る'.html_safe,
     new_itinerary_destination_path(@itinerary, current_day: @current_day),
     class: 'footer-link' %>
   <button id="register_time" class="footer-link">しおりを<br>登録する</button>
 </footer>

