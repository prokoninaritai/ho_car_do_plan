<div class="registration-page">
  <div class="top-banner"></div>
  <div class="form-container">
    <h1>新規登録</h1>
    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { data: { turbo: false } }) do |f| %>
      <% if resource.errors.any? %>
        <div class="error-messages">
          <% resource.errors.full_messages.each do |message| %>
            <p><%= message %></p>
          <% end %>
        </div>
      <% end %>
      <div class="form-group">
        <%= f.label :nickname, 'ニックネーム' %>
        <%= f.text_field :nickname, required: true, autofocus: true %>
      </div>
      <div class="form-group">
        <%= f.label :email, 'メールアドレス' %>
        <%= f.email_field :email, required: true %>
      </div>
      <div class="form-group">
        <%= f.label :password, 'ログインパスワード' %>
        <%= f.password_field :password, required: true %>
      </div>
      <div class="form-actions">
        <%= f.submit '登録する', class: 'submit-button' %>
      </div>
    <% end %>
  </div>
  <div class="bottom-banner"></div>
</div>