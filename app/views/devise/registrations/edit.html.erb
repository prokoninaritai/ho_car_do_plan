<!-- ヘッダー -->
<header class="header">
  <%= link_to 'HoCarDoPlan', authenticated_root_path, class: 'header-logo' %>
  <div class="welcome">マイページ</div>
  <%= link_to 'ログアウト', destroy_user_session_path, data: { turbo_method: :delete }, class: 'logout-button' %>
</header>

<main>
<div class="main-contents mypage-contents">

  <!-- 自宅登録セクション -->
  <div class="mypage-section">
    <h3 class="mypage-section-title">自宅の登録</h3>
    <% if resource.home_address.present? %>
      <div class="mypage-current-home">
        <span class="mypage-label">現在の登録:</span>
        <span class="mypage-value"><%= resource.home_address %></span>
      </div>
    <% else %>
      <p class="mypage-description">自宅を登録すると、経路選択画面で「自宅を選ぶ」ボタンが使えます。</p>
    <% end %>
    <%= link_to '自宅を登録・変更する', users_home_path, class: 'mypage-home-link' %>
  </div>

  <!-- アカウント設定セクション -->
  <div class="mypage-section">
    <h3 class="mypage-section-title">アカウント設定</h3>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="mypage-field">
        <%= f.label :nickname, 'ニックネーム' %><br />
        <%= f.text_field :nickname %>
      </div>

      <div class="mypage-field">
        <%= f.label :email, 'メールアドレス' %><br />
        <%= f.email_field :email, autofocus: true, autocomplete: "email" %>
      </div>

      <div class="mypage-field">
        <%= f.label :password, 'パスワード' %> <i>(変更しない場合は空欄)</i><br />
        <%= f.password_field :password, autocomplete: "new-password" %>
      </div>

      <div class="mypage-field">
        <%= f.label :password_confirmation, 'パスワード確認' %><br />
        <%= f.password_field :password_confirmation, autocomplete: "new-password" %>
      </div>

      <div class="mypage-field">
        <%= f.label :current_password, '現在のパスワード' %> <i>(変更の確認に必要です)</i><br />
        <%= f.password_field :current_password, autocomplete: "current-password" %>
      </div>

      <div class="mypage-actions">
        <%= f.submit "更新する", class: "mypage-submit-btn" %>
      </div>
    <% end %>
  </div>

  <div class="mypage-section">
    <h3 class="mypage-section-title">アカウント削除</h3>
    <div>
      <%= button_to "アカウントを削除する", registration_path(resource_name), data: { confirm: "本当に削除しますか？", turbo_confirm: "本当に削除しますか？" }, method: :delete, class: "mypage-delete-btn" %>
    </div>
  </div>

  <%= link_to 'ダッシュボードに戻る', authenticated_root_path, class: "mypage-back-link" %>
</div>
</main>

<!-- フッター -->
<footer class="footer">
  <div class="footer-container footer-thin"></div>
</footer>

