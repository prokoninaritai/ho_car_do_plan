<div class="login-page">
  <div class="top-banner"></div>
  <div class="form-container">
    <h1>ログイン</h1>
    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { data: { turbo: false } }) do |f| %>
      <div class="form-group">
        <%= f.label :email, 'メールアドレス' %>
        <%= f.email_field :email, required: true, autofocus: true %>
      </div>
      <div class="form-group">
        <%= f.label :password, 'パスワード' %>
        <%= f.password_field :password, required: true %>
      </div>
      <div class="form-actions">
        <%= f.submit 'ログイン', class: 'submit-button' %>
      </div>
    <% end %>
    <p class="link">
      <%= link_to '新規登録はこちら', new_registration_path(resource_name) %>
    </p>
  </div>
  <div class="bottom-banner"></div>
</div>